# ─── Server ───
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:4200,http://localhost:8080
FRONTEND_BASE_URL=http://localhost:4200
API_BASE_URL=http://localhost:4000

# ─── Auth ───
JWT_SECRET=replace-with-a-long-random-secret

# ─── MySQL ───
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=agendapro
MYSQL_TENANT_DB_PREFIX=agendapro_tenant_
MYSQL_CONNECTION_LIMIT=10

# ─── Legacy SQLite Migration (one-time) ───
MYSQL_AUTO_MIGRATE_FROM_SQLITE=true
SQLITE_CONTROL_DB_PATH=storage/control.db
SQLITE_TENANTS_DB_DIR=storage/tenants

# ─── Email (SMTP) ───
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@agendapro.com

# ─── Google Calendar Integration ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/integrations/google/callback

# ─── WhatsApp Cloud API (Meta) ───
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
